# Google Drive API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_monitored_folder_id

# OpenAI API
OPENAI_API_KEY=your_openai_api_key
CUSTOM_GPT_ID=your_custom_gpt_id

# Etsy API v3 (OAuth 2.0)
ETSY_API_KEY=your_etsy_api_key
ETSY_API_SECRET=your_etsy_api_secret
ETSY_ACCESS_TOKEN=your_etsy_access_token
ETSY_REFRESH_TOKEN=your_etsy_refresh_token
ETSY_SHOP_ID=your_etsy_shop_id
ETSY_CLIENT_ID=your_etsy_client_id
ETSY_REDIRECT_URI=http://localhost:3000/auth/etsy/callback
USE_ETSY_API=false
USE_ETSY_SELENIUM=false

# OneClickLister API
ONECLICKLISTER_API_KEY=your_oneclicklister_api_key
ONECLICKLISTER_API_SECRET=your_oneclicklister_api_secret
ONECLICKLISTER_USER_CODE=your_oneclicklister_user_code
ONECLICKLISTER_STORE_ID=your_oneclicklister_store_id
ONECLICKLISTER_API_URL=https://oneclicklister.com
USE_ONECLICKLISTER=false
ONECLICKLISTER_DEFAULT_STORE=your_default_store_id

# Etsy Selenium Login (Otomatik listeleme için)
ETSY_EMAIL=your_etsy_email
ETSY_PASSWORD=your_etsy_password

# Processing Settings
OUTPUT_IMAGE_SIZE=3000
PROCESSING_INTERVAL=60000

# Background Processing Options
ADD_BACKGROUND=true
BACKGROUND_TYPE=image
BACKGROUND_COLOR=#FFFFFF
GRADIENT_COLORS=#FFFFFF,#F0F0F0
BACKGROUND_IMAGE_PATH=./test-backgrounds
REMOVE_BACKGROUND=true

# Background Types:
# - solid: Düz renk (BACKGROUND_COLOR kullanır)
# - gradient: Degrade (GRADIENT_COLORS kullanır)
# - image: Tek arka plan fotoğrafı (BACKGROUND_IMAGE_PATH dosya yolu)
# - random: Rastgele arka plan (BACKGROUND_IMAGE_PATH klasör yolu)